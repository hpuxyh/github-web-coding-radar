{
  "timezone": "Asia/Shanghai",
  "history_path": "data/repo_history.json",
  "output_dir": "output",
  "per_page": 40,
  "pages": 1,
  "frontier_limit": 15,
  "product_limit": 15,
  "top_limit": 15,
  "rising_limit": 15,
  "xhs_count": 5,
  "max_readmes": 12,
  "readme_excerpt_chars": 700,
  "rising_max_age_days": 180,
  "request_interval_seconds": 6.5,
  "request_timeout_seconds": 60,
  "retries": 2,
  "all_time_queries": [
    "topic:llm stars:>=20000 archived:false",
    "topic:developer-tools stars:>=10000 archived:false",
    "topic:code-editor stars:>=5000 archived:false",
    "topic:ai-agent stars:>=5000 archived:false"
  ],
  "rising_queries": [
    "created:>={date_60} stars:>=20 archived:false topic:coding-agent",
    "created:>={date_60} stars:>=20 archived:false topic:mcp",
    "created:>={date_60} stars:>=20 archived:false topic:web-ide",
    "created:>={date_60} stars:>=20 archived:false topic:ai-agent",
    "created:>={date_60} stars:>=20 archived:false vibe-coding"
  ],
  "frontier_queries": [
    "created:>={date_90} stars:>=50 archived:false topic:coding-agent",
    "created:>={date_90} stars:>=50 archived:false topic:mcp",
    "created:>={date_90} stars:>=50 archived:false topic:ai-agent",
    "created:>={date_90} stars:>=50 archived:false claude-code",
    "created:>={date_90} stars:>=50 archived:false topic:agent-framework",
    "pushed:>={date_14} stars:>=1000 archived:false topic:developer-tools"
  ],
  "product_queries": [
    "created:>={date_90} stars:>=30 archived:false topic:app-builder",
    "created:>={date_90} stars:>=30 archived:false topic:low-code",
    "created:>={date_90} stars:>=30 archived:false topic:no-code",
    "created:>={date_90} stars:>=30 archived:false topic:web-ide",
    "created:>={date_90} stars:>=30 archived:false topic:ai-coding",
    "created:>={date_90} stars:>=30 archived:false prototype"
  ]
}
